---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found — cloudplanner.org"
  description="This page doesn't exist. Browse our FinOps guides and cloud cost tools."
>
  <section style="text-align:center; padding: 6rem 1rem;">
    <div style="font-size:4rem; margin-bottom:1rem;">☁</div>
    <h1 style="font-size:2rem; margin-bottom:0.75rem;">Page not found</h1>
    <p style="color:var(--color-text-muted); margin-bottom:2rem;">
      That page doesn't exist — or it may have moved.
    </p>
    <a href="/" style="
      display:inline-block;
      padding:0.6rem 1.4rem;
      background:var(--color-brand);
      color:#fff;
      border-radius:8px;
      font-weight:500;
      text-decoration:none;
    ">← Back to home</a>
  </section>
</BaseLayout>

---
const year = new Date().getFullYear();

const footerLinks = [
  {
    heading: 'FinOps Guides',
    links: [
      { href: '/finops/', label: 'FinOps hub' },
      { href: '/finops/cloud-cost-optimisation/', label: 'Cost optimisation' },
      { href: '/finops/best-finops-tools/', label: 'Best tools' },
      { href: '/finops/finops-kpis/', label: 'KPIs & metrics' },
    ],
  },
  {
    heading: 'Calculators',
    links: [
      { href: '/calculators/aws-cost-calculator/', label: 'AWS calculator' },
      { href: '/calculators/reserved-instance-calculator/', label: 'RI calculator' },
      { href: '/calculators/azure-cost-calculator/', label: 'Azure calculator' },
    ],
  },
  {
    heading: 'Compare',
    links: [
      { href: '/comparisons/aws-vs-azure/', label: 'AWS vs Azure' },
      { href: '/comparisons/reserved-vs-savings-plans/', label: 'RIs vs savings plans' },
      { href: '/finops/best-finops-tools/', label: 'FinOps platforms' },
    ],
  },
];
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo">☁ cloudplanner.org</a>
      <p class="footer-tagline">Free FinOps guides, calculators, and tools to help engineering teams reduce cloud spend.</p>
    </div>

    {footerLinks.map(col => (
      <div class="footer-col">
        <div class="footer-heading">{col.heading}</div>
        <ul role="list">
          {col.links.map(link => (
            <li><a href={link.href} class="footer-link">{link.label}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="footer-bottom">
    <div class="container">
      <span>© {year} cloudplanner.org — independent FinOps resource.</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 5rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-subtle);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 2.5rem;
    padding-top: 3rem;
    padding-bottom: 3rem;
  }

  .footer-logo {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    display: block;
    margin-bottom: 0.75rem;
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    max-width: 260px;
    line-height: 1.5;
  }

  .footer-heading {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }

  .footer-link {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .footer-link:hover { color: var(--color-text); text-decoration: none; }

  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding: 1rem 0;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .footer-inner { grid-template-columns: 1fr 1fr; }
    .footer-brand { grid-column: 1 / -1; }
  }

  @media (max-width: 480px) {
    .footer-inner { grid-template-columns: 1fr; }
  }
</style>

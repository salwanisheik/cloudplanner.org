# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub — it is already in .gitignore.

# Airtable — get these from airtable.com/account
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_COMPARISONS=appXXXXXXXXXXXXXX
AIRTABLE_BASE_GUIDES=appXXXXXXXXXXXXXX
AIRTABLE_BASE_CALCULATORS=appXXXXXXXXXXXXXX
AIRTABLE_BASE_TEMPLATES=appXXXXXXXXXXXXXX
AIRTABLE_BASE_MIGRATIONS=appXXXXXXXXXXXXXX

# Google Analytics 4 — get from analytics.google.com
PUBLIC_GA4_ID=G-XXXXXXXXXX

# Mixpanel — get from mixpanel.com
PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token_here
